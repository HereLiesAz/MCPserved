<?xml version="1.0" encoding="utf-8"?>
<!--
    Nothing leaves the device.

    The pairing keys and the grant table are the only persisted state, and both
    are precisely what must not be restored onto a different handset. A cloud
    backup of this application would be a cloud backup of the authority to
    control a phone.
-->
<data-extraction-rules>
    <cloud-backup>
        <exclude domain="root" />
        <exclude domain="file" />
        <exclude domain="database" />
        <exclude domain="sharedpref" />
    </cloud-backup>
    <device-transfer>
        <exclude domain="root" />
        <exclude domain="file" />
        <exclude domain="database" />
        <exclude domain="sharedpref" />
    </device-transfer>
</data-extraction-rules>
