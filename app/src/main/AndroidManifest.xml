<?xml version="1.0" encoding="utf-8"?>
<!--
    MCPserved.

    Permission notes, since several here are unusual and all of them are the
    kind a reviewer should be suspicious of:

    - BIND_ACCESSIBILITY_SERVICE is the entire product: it is what lets the app
      read the screen and dispatch input on the user's behalf. It is also the
      permission most abused by malware, which is why the app is inert until the
      user grants specific packages, why every session is time-boxed and shown in
      an ongoing notification, and why control arrives only over a local loopback
      port the user bridges themselves — never from the network.
    - INTERNET is required by the platform to open any socket, including the
      loopback ServerSocket the control channel binds to 127.0.0.1. The app makes
      no outbound or remote connections; the only reachable listener is on
      loopback, reached through an `adb forward` tunnel the user sets up.
    - WAKE_LOCK holds the screen during a session. Accessibility events stop and
      the node tree empties once the device locks, so a session on a dark screen
      would fail every action while appearing merely unlucky.
    - FOREGROUND_SERVICE_SPECIAL_USE rather than a narrower type: no declared
      category describes "user-authorized device automation", and claiming one
      that does not fit would be a false declaration to the platform.
-->
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.WAKE_LOCK" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_SPECIAL_USE" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <uses-permission android:name="android.permission.CAMERA" />
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />

    <!--
        Reads the full installed-package list for the grants screen. Declared
        explicitly because Android 11 filters package visibility by default, and
        a partial list would silently hide applications the user meant to grant.
    -->
    <uses-permission
        android:name="android.permission.QUERY_ALL_PACKAGES"
        tools:ignore="QueryAllPackagesPermission" />

    <uses-feature android:name="android.hardware.camera" android:required="false" />

    <application
        android:name=".McpApplication"
        android:allowBackup="false"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:supportsRtl="true"
        android:theme="@style/Theme.McpServed"
        tools:targetApi="34">

        <activity
            android:name=".ui.MainActivity"
            android:exported="true"
            android:launchMode="singleTask"
            android:screenOrientation="portrait"
            android:theme="@style/Theme.McpServed">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!--
            Holds the resolver, the grant store, the session, and the loopback
            control server. Runs whenever the app is armed rather than only during
            a session: a service that existed only while a session ran could never
            be told to begin one.
        -->
        <service
            android:name=".service.ControlService"
            android:exported="false"
            android:foregroundServiceType="specialUse">
            <property
                android:name="android.app.PROPERTY_SPECIAL_USE_FGS_SUBTYPE"
                android:value="User-authorized on-device automation over a local loopback connection" />
        </service>

        <service
            android:name=".service.McpAccessibilityService"
            android:exported="true"
            android:label="@string/a11y_label"
            android:permission="android.permission.BIND_ACCESSIBILITY_SERVICE">
            <intent-filter>
                <action android:name="android.accessibilityservice.AccessibilityService" />
            </intent-filter>
            <meta-data
                android:name="android.accessibilityservice"
                android:resource="@xml/accessibility_service_config" />
        </service>

        <service
            android:name=".service.NotificationMirror"
            android:exported="true"
            android:label="@string/notif_listener_label"
            android:permission="android.permission.BIND_NOTIFICATION_LISTENER_SERVICE">
            <intent-filter>
                <action android:name="android.service.notification.NotificationListenerService" />
            </intent-filter>
        </service>

        <receiver
            android:name=".service.BootReceiver"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.BOOT_COMPLETED" />
            </intent-filter>
        </receiver>

    </application>
</manifest>
